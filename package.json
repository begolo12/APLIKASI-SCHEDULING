{
  "name": "flowboard",
  "version": "0.1.0",
  "description": "FlowBoard - Aplikasi Scheduling Trello-like (Electron + Neon Postgres)",
  "main": "electron/main.js",
  "author": "FlowBoard",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:repair-electron && concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:repair-electron": "node scripts/repair-electron.js",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "db:check": "node scripts/check-db.js",
    "test": "node --no-warnings tests/helpers.test.js",
    "build": "vite build",
    "dist": "npm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.4",
    "dotenv": "^16.4.5",
    "sortablejs": "^1.15.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.flowboard.app",
    "productName": "FlowBoard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "forceCodeSigning": false,
      "publish": [
        {
          "provider": "generic",
          "url": "https://example.invalid/flowboard"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": false
    }
  }
}
